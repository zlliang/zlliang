---
import { createI18n } from "../i18n"

import type { Locale } from "../i18n"

interface Props {
  author: string
  /** Page locale. Defaults to the configured `locale`. */
  locale?: Locale
}

const { author, locale } = Astro.props
const t = createI18n(locale)
---

<footer class="mt-16 mb-8 text-xs text-neutral-400 dark:text-neutral-600">
  <div class="space-x-2">
    <a href="https://github.com/zlliang" class="icon-[simple-icons--github] secondary" aria-label="GitHub" />
    <a href="https://x.com/zlliang96" class="icon-[simple-icons--x] secondary scale-80!" aria-label="X" />
    <a href="https://www.instagram.com/zlliang96" class="icon-[simple-icons--instagram] secondary scale-90!" aria-label="Instagram" />
    <a href="https://xhslink.com/m/7jXHMqj1j6Q" class="icon-[simple-icons--xiaohongshu] secondary ml-1 mr-2.5 scale-160!" aria-label="Xiaohongshu" />
    <a href="https://space.bilibili.com/30470407" class="icon-[simple-icons--bilibili] secondary" aria-label="Bilibili" />
  </div>
  <div class="mt-2">
    <a href="https://creativecommons.org/licenses/by/4.0/" class="secondary">CC BY 4.0</a>
    <span>2025–PRESENT</span>
    <span class="icon-[lucide--copyright] scale-90" />
    <a href="https://zlliang.me/" class="secondary">{author}</a>
    <span class="hidden sm:inline">
      <span class="icon-[lucide--dot]" />
      <span>{t.builtWithPrefix} <a href="https://astro.build" class="secondary">Astro</a> {t.builtWithSuffix}</span>
    </span>
  </div>
  <div class="mt-1 sm:hidden">
    <span>{t.builtWithPrefix} <a href="https://astro.build" class="secondary">Astro</a> {t.builtWithSuffix}</span>
  </div>
</footer>
