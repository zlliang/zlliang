---
import { render } from "astro:content"

import PageTitle from "./PageTitle.astro"
import ContentEditButton from "./ContentEditButton.astro"

import { createI18n } from "../i18n"
import { getSeriesById } from "../content"

import type { CollectionEntry } from "astro:content"
import type { Locale } from "../i18n"

interface Props {
  post: CollectionEntry<"posts">
  locale?: Locale
}

const { post, locale } = Astro.props
const t = createI18n(locale)

const series = post.data.series ? await getSeriesById(post.data.series.id) : null
const { Content } = await render(post)
---

<div class="post-content">
  <PageTitle>
    <Fragment>{post.data.title}</Fragment>
    <div slot="subtitle" class="space-x-1">
      <span>{t.formatDate(post.data.created)}</span>
      {post.data.pinned && <span class="icon-[lucide--pin]" />}
      {series && <span class="px-1">{t.partOfSeries}<a href={`/posts/series/${series.id}`}>{series.data.title}</a></span>}
      {post.data.draft && <span class="text-amber-600 dark:text-amber-400">{t.draft}</span>}
      <ContentEditButton filePath={post.filePath} />
    </div>
  </PageTitle>

  <div class="mb-4">
    <Content />
  </div>
</div>
