---
import { Image } from "astro:assets"

import logoHack from "../assets/logo-hack.png"
import logoMuse from "../assets/logo-muse.png"

import { cn } from "../index"

import type { ImageMetadata } from "astro"

type Site = "hack" | "muse"
type Lang = "en" | "zh"

interface Props {
  site: Site
  lang: Lang
}

interface SiteConfig {
  href: string
  domain: string
  logo: ImageMetadata
  copy: Record<
    Lang,
    {
      title: string
      descriptionLines: string[]
      languageLabel: string
      logoAlt: string
    }
  >
}

const { site, lang } = Astro.props

const siteConfig: Record<Site, SiteConfig> = {
  hack: {
    href: "https://hack.zlliang.me",
    domain: "hack.zlliang.me",
    logo: logoHack,
    copy: {
      en: {
        title: "Hack",
        descriptionLines: ["In this ever-changing world of technology, trying to see things a little more clearly."],
        languageLabel: "English",
        logoAlt: "Logo of hack.zlliang.me",
      },
      zh: {
        title: "技术手记",
        descriptionLines: ["在这个每天都在变的技术世界里，", "看得更清楚一点。"],
        languageLabel: "英文",
        logoAlt: "hack.zlliang.me 的图标",
      },
    },
  },
  muse: {
    href: "https://muse.zlliang.me",
    domain: "muse.zlliang.me",
    logo: logoMuse,
    copy: {
      en: {
        title: "Muse",
        descriptionLines: ["Slowly writing down small things, passing thoughts, and the ones that linger a little longer."],
        languageLabel: "Chinese",
        logoAlt: "Logo of muse.zlliang.me",
      },
      zh: {
        title: "随想手记",
        descriptionLines: ["慢慢记下一些小事和随想，还有那些", "停留更久的念头。"],
        languageLabel: "中文",
        logoAlt: "muse.zlliang.me 的图标",
      },
    },
  },
}

const { href, domain, logo, copy } = siteConfig[site]
const { title, descriptionLines, languageLabel, logoAlt } = copy[lang]

const accentClasses = {
  hack: "hover:border-hack-400 dark:hover:border-hack-600 hover:bg-hack-50 dark:hover:bg-hack-950 hover:text-hack-500!",
  muse: "hover:border-muse-400 dark:hover:border-muse-600 hover:bg-muse-50 dark:hover:bg-muse-950 hover:text-muse-500!",
}

const secondaryClasses = {
  hack: "text-neutral-500 group-hover:text-hack-400 dark:group-hover:text-hack-600",
  muse: "text-neutral-500 group-hover:text-muse-400 dark:group-hover:text-muse-600",
}
---

<a
  href={href}
  class={cn("secondary group flex gap-4 px-4 py-3 border border-neutral-200 dark:border-neutral-800", accentClasses[site])}
>
  <Image src={logo} alt={logoAlt} class="size-8" loading="eager" />
  <div class="flex-1">
    <div class="flex items-center justify-between gap-2">
      <div class="font-bold">{title}</div>
      <div class={cn("shrink-0 text-sm", secondaryClasses[site])}>{languageLabel}</div>
    </div>
    <div class={cn("text-sm", secondaryClasses[site])}>{domain}</div>
    <div class="mt-2 text-sm leading-6">
      {descriptionLines.map((line) => <div>{line}</div>)}
    </div>
  </div>
</a>
