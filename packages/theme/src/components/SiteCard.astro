---
import { Image } from "astro:assets"

import { siteData } from "@zlliang/data"
import { cn } from "../styles"

import type { Site, Locale } from "@zlliang/data"

interface Props {
  site: Site
  locale: Locale
}

const { site, locale } = Astro.props

const { href, domain, logo, copy } = siteData[site]
const { title, descriptionLines, localeLabel } = copy[locale]

const accentClasses = {
  mesh: "hover:border-blue-400 dark:hover:border-blue-600 hover:bg-blue-50 dark:hover:bg-blue-950 hover:text-blue-500!",
  muse: "hover:border-indigo-400 dark:hover:border-indigo-600 hover:bg-indigo-50 dark:hover:bg-indigo-950 hover:text-indigo-500!",
}

const secondaryClasses = {
  mesh: "text-neutral-500 group-hover:text-blue-400 dark:group-hover:text-blue-600",
  muse: "text-neutral-500 group-hover:text-indigo-400 dark:group-hover:text-indigo-600",
}
---

<a
  href={href}
  class={cn("secondary group flex gap-4 px-4 py-3 border border-neutral-200 dark:border-neutral-800", accentClasses[site])}
>
  <Image src={logo} alt={`Logo of ${title}`} class="size-8" loading="eager" />
  <div class="flex-1">
    <div class="flex items-center justify-between gap-2">
      <div class="font-bold">{title}</div>
      <div class={cn("shrink-0 text-sm", secondaryClasses[site])}>{localeLabel}</div>
    </div>
    <div class={cn("text-sm", secondaryClasses[site])}>{domain}</div>
    <div class="mt-2 text-sm leading-6">
      {descriptionLines.map((line) => <div>{line}</div>)}
    </div>
  </div>
</a>
