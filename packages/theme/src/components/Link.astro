---
interface Props extends astroHTML.JSX.AnchorHTMLAttributes {
  external?: boolean
}

const { external: _external, ...attrs } = Astro.props
const external = _external ?? (attrs.href?.toString().startsWith("http") || attrs.href?.toString().startsWith("//"))
---

<a {...attrs} {...(external ? { target: "_blank", rel: "noopener" } : {})}><slot /></a>
