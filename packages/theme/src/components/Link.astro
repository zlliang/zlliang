---
import { cn } from "../index"

interface Props extends astroHTML.JSX.AnchorHTMLAttributes {
  href?: string
  external?: boolean
  class?: string
}

const { href, class: className, ...attrs } = Astro.props
const external = Astro.props.external ?? (href?.startsWith("http") || href?.startsWith("//"))
---

<a
  href={href}
  class={cn(className)}
  {...(external ? { target: "_blank", rel: "noopener" } : {})}
  {...attrs}
><slot /></a>
