---
import { Font } from "astro:assets"
import VercelWebAnalytics from "@vercel/analytics/astro"
import VercelSpeedInsights from "@vercel/speed-insights/astro"

import Header from "./Header.astro"
import Footer from "./Footer.astro"
import Aside from "./Aside.astro"

import { t, themeConfig, themeLogo } from "../runtime/config"

import "../styles/main.css"

interface Props {
  title?: string
  description?: string
  aside?: boolean
  showRecentPosts?: boolean
  showSearch?: boolean
  noindex?: boolean
}

const { title: rawTitle, description = themeConfig.description, aside = true, showRecentPosts = true, showSearch = true, noindex = false } = Astro.props
const title = rawTitle ? `${rawTitle} - ${themeConfig.title}` : themeConfig.title
const url = Astro.url
---

<!DOCTYPE html>
<html lang={t.htmlLang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  {/* Favicon */}
  <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  {/* Fonts */}
  <Font cssVariable="--font-public-sans" preload />
  <Font cssVariable="--font-roboto-mono" preload />

  {/* SEO, OpenGraph and Twitter */}
  <link rel="canonical" href={url} />
  {Boolean(description) && <meta name="description" content={description} />}
  {noindex && <meta name="robots" content="noindex, follow" />}
  <meta property="og:site_name" content={themeConfig.title} />
  <meta property="og:url" content={url} />
  <meta property="og:title" content={title} />
  {Boolean(description) && <meta property="og:description" content={description} />}
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  {Boolean(description) && <meta name="twitter:description" content={description} />}
  {themeConfig.twitterCreator && <meta name="twitter:creator" content={themeConfig.twitterCreator} />}

  {/* Title */}
  <title>{title}</title>
</head>
<body>
  <div class="flex flex-col min-h-dvh max-w-3xl lg:max-w-6xl m-auto px-6">
    <Header logo={themeLogo} title={themeConfig.title}>
      <Fragment slot="menu">
        <a href="/search" class="lg:hidden"><span class="icon-[lucide--search]" /> {t.search}</a>
        <a href={themeConfig.aboutHref}><span class="icon-[lucide--user]" /> {t.about}</a>
      </Fragment>
    </Header>
    <div class="flex-1 lg:flex gap-12 w-full">
      <main class="flex-1 min-w-0">
        <slot />
      </main>
      {aside && (
        <Aside showSearch={showSearch} showRecentPosts={showRecentPosts} class="mt-16 lg:mt-0 lg:shrink-0 lg:w-80">
          <Fragment slot="prefix"><slot name="aside-prefix" /></Fragment>
          <Fragment slot="suffix"><slot name="aside-suffix" /></Fragment>
        </Aside>
      )}
    </div>
    <Footer author={themeConfig.footerAuthor} builtWithPrefix={t.builtWithPrefix} builtWithSuffix={t.builtWithSuffix} />
  </div>

  {/* Vercel */}
  <VercelWebAnalytics />
  <VercelSpeedInsights />
</body>
</html>
