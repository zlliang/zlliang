---
import { Image } from "astro:assets"

import { cn } from "../index"

import type { ImageMetadata } from "astro"

interface Props {
  href: string
  title: string
  description: string
  domain: string
  languageLabel: string
  logo: ImageMetadata
  logoAlt: string
  accent: "hack" | "muse"
  class?: string
}

const {
  href,
  title,
  description,
  domain,
  languageLabel,
  logo,
  logoAlt,
  accent,
  class: className,
} = Astro.props

const accentClasses = {
  hack: "hover:border-hack-400 dark:hover:border-hack-600 hover:bg-hack-50 dark:hover:bg-hack-950 hover:text-hack-500!",
  muse: "hover:border-muse-400 dark:hover:border-muse-600 hover:bg-muse-50 dark:hover:bg-muse-950 hover:text-muse-500!",
}

const secondaryClasses = {
  hack: "text-neutral-500 group-hover:text-hack-400 dark:group-hover:text-hack-600",
  muse: "text-neutral-500 group-hover:text-muse-400 dark:group-hover:text-muse-600",
}
---

<a
  href={href}
  class={cn(
    "secondary group flex gap-4 border border-neutral-200 p-4 dark:border-neutral-800",
    accentClasses[accent],
    className,
  )}
>
  <Image src={logo} alt={logoAlt} class="size-8" loading="eager" />
  <div class="flex-1">
    <div class="flex items-center justify-between gap-2">
      <div class="font-bold">{title}</div>
      <div class={cn("shrink-0 text-sm", secondaryClasses[accent])}>{languageLabel}</div>
    </div>
    <div class={cn("text-sm", secondaryClasses[accent])}>{domain}</div>
    <div class="mt-2 text-sm">{description}</div>
  </div>
</a>
