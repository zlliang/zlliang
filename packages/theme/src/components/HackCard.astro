---
import SiteLinkCard from "./SiteLinkCard.astro"

import logoHack from "../assets/logo-hack.png"

interface Props {
  lang?: "en" | "zh"
  class?: string
}

const { lang = "en", class: className } = Astro.props

const copy = {
  en: {
    title: "Hack",
    descriptionLines: ["In this ever-changing world of technology, trying to see things a little more clearly."],
    languageLabel: "English",
    logoAlt: "Logo of hack.zlliang.me",
  },
  zh: {
    title: "技术手记",
    descriptionLines: ["在这个每天都在变的技术世界里，", "看得更清楚一点。"],
    languageLabel: "英文",
    logoAlt: "hack.zlliang.me 的图标",
  },
}[lang]
---

<SiteLinkCard
  href="https://hack.zlliang.me"
  title={copy.title}
  descriptionLines={copy.descriptionLines}
  domain="hack.zlliang.me"
  languageLabel={copy.languageLabel}
  logo={logoHack}
  logoAlt={copy.logoAlt}
  accent="hack"
  class={className}
/>
