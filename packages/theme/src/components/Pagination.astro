---
interface Props {
  current: number
  last: number
  url: {
    current: string
    first?: string
    prev?: string
    next?: string
    last?: string
  }
  label?: string
}

const { current, last, url, label = "Page" } = Astro.props
---

<div class="flex justify-end items-center text-sm gap-2">
  {Boolean(url.first || url.prev) && (
    <div>
      {url.first && <a href={url.first}><span class="icon-[lucide--chevrons-left]" /></a>}
      {url.prev && <a href={url.prev}><span class="icon-[lucide--chevron-left]" /></a>}
    </div>
  )}
  <div>{label} {current} / {last}</div>
  {Boolean(url.next || url.last) && (
    <div>
      {url.next && <a href={url.next}><span class="icon-[lucide--chevron-right]" /></a>}
      {url.last && <a href={url.last}><span class="icon-[lucide--chevrons-right]" /></a>}
    </div>
  )}
</div>
