---
import SiteLinkCard from "./SiteLinkCard.astro"

import logoMuse from "../assets/logo-muse.png"

interface Props {
  lang?: "en" | "zh"
  class?: string
}

const { lang = "en", class: className } = Astro.props

const copy = {
  en: {
    title: "Muse",
    descriptionLines: ["Slowly writing down small things, passing thoughts, and the ones that linger a little longer."],
    languageLabel: "Chinese",
    logoAlt: "Logo of muse.zlliang.me",
  },
  zh: {
    title: "随想手记",
    descriptionLines: ["慢慢记下一些小事和随想，还有那些", "停留更久的念头。"],
    languageLabel: "中文",
    logoAlt: "muse.zlliang.me 的图标",
  },
}[lang]
---

<SiteLinkCard
  href="https://muse.zlliang.me"
  title={copy.title}
  descriptionLines={copy.descriptionLines}
  domain="muse.zlliang.me"
  languageLabel={copy.languageLabel}
  logo={logoMuse}
  logoAlt={copy.logoAlt}
  accent="muse"
  class={className}
/>
