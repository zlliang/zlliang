---
import { Image } from "astro:assets"

import type { ImageMetadata } from "astro"

interface Props {
  logo: ImageMetadata
  title: string
  homeHref?: string
  logoAlt?: string
}

const { logo, title, homeHref = "/", logoAlt = "logo" } = Astro.props
---

<header class="flex justify-between items-center h-16 mb-12">
  <div class="flex items-center gap-2">
    <a href={homeHref} class="nocolor flex items-center gap-2 font-display">
      <Image src={logo} alt={logoAlt} class="size-6" loading="eager" />
      <strong>{title}</strong>
    </a>
  </div>
  <div class="flex items-center gap-4">
    <slot name="menu" />
  </div>
</header>
