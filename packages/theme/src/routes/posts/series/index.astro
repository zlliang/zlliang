---
import PageTitle from "../../../components/PageTitle.astro"
import Layout from "../../../components/Layout.astro"
import PostList from "../../../components/PostList.astro"

import { createI18n } from "../../../i18n"
import { getPosts, getSeries, filterPostsInSeries } from "../../../content"

const t = createI18n()
const series = await getSeries()
const posts = await getPosts()

const title = t.series
---

<Layout title={title} showRecentPosts={false}>
  <PageTitle>
    <Fragment>{title}</Fragment>
    <div slot="subtitle" class="space-y-1">
      <div>{t.seriesCountSubtitle(series.length)}</div>
      <div class="flex justify-between gap-4">
        <span>{t.oldestFirst}</span>
        <a href="/posts"><span class="icon-[lucide--corner-left-up]" /> {t.backToAllPosts}</a>
      </div>
    </div>
  </PageTitle>

  {series.length > 0 ? series.map((series) => (
    <h2><a href={`/posts/series/${series.id}`}>{series.data.title}</a></h2>
    <Fragment>{series.data.description && <p>{series.data.description}</p>}</Fragment>
    <Fragment>{filterPostsInSeries(posts, series.id).length > 0 ? <PostList posts={filterPostsInSeries(posts, series.id)} showSeries={false} /> : <p class="text-neutral-500">{t.postsEmpty}</p>}</Fragment>
  )) : <p class="text-neutral-500">{t.seriesEmpty}</p>}
</Layout>
