---
import { Image } from "astro:assets"

import Link from "@zlliang/theme/components/Link.astro"
import Section from "@zlliang/theme/components/Section.astro"
import Layout from "@/components/Layout.astro"

import { renderFragment } from "@/utils/content"

import logoTech from "@/assets/images/logo-tech.png"
import logoDays from "@/assets/images/logo-days.png"

const Bio = await renderFragment("bio-en")
---

<Layout lang="en">
  <div class="mb-12">
    <Bio />
  </div>

  {/* Writing */}
  <Section title="Writing">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <Link href="https://tech.zlliang.me" external={false} class="secondary group flex gap-4 p-4 border border-neutral-200 dark:border-neutral-800 hover:border-tech-400 dark:hover:border-tech-600 hover:bg-tech-50 dark:hover:bg-tech-950 hover:text-tech-500!">
        <Image src={logoTech} alt="Logo of tech.zlliang.me" class="size-8" loading="eager" />
        <div class="flex-1">
          <div><span class="font-bold">Zilong's Tech Notes</span> (English)</div>
          <div class="text-sm text-neutral-500 group-hover:text-tech-400 dark:group-hover:text-tech-600">tech.zlliang.me</div>
          <div class="mt-2 text-sm">My tech exploration journal</div>
        </div>
      </Link>
      <Link href="https://days.zlliang.me" external={false} class="secondary group flex gap-4 p-4 border border-neutral-200 dark:border-neutral-800 hover:border-days-400 dark:hover:border-days-600 hover:bg-days-50 dark:hover:bg-days-950 hover:text-days-500!">
        <Image src={logoDays} alt="Logo of days.zlliang.me" class="size-8" loading="eager" />
        <div class="flex-1">
          <div><span class="font-bold">Zilong's Days</span> (Chinese)</div>
          <div class="text-sm text-neutral-500 group-hover:text-days-400 dark:group-hover:text-days-600">days.zlliang.me</div>
          <div class="mt-2 text-sm">My life reflection journal</div>
        </div>
      </Link>
    </div>
  </Section>
</Layout>
