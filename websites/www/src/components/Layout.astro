---
import { Font } from "astro:assets"
import VercelWebAnalytics from "@vercel/analytics/astro"
import VercelSpeedInsights from "@vercel/speed-insights/astro"

import Header from "@zlliang/theme/components/Header.astro"
import Footer from "@zlliang/theme/components/Footer.astro"
import Link from "@zlliang/theme/components/Link.astro"

import { getTitle } from "@/utils/site"
import { locales, t } from "@/utils/i18n"

import type { Locale } from "@/utils/i18n"

import "@/styles/main.css"

import logo from "@/assets/images/logo.png"

interface Props {
  title?: string
  description?: string
  lang?: Locale
  showMenu?: boolean
}

const { title: rawTitle, description, lang = "en", showMenu = true } = Astro.props
const title = getTitle(lang, rawTitle)
const url = new URL(Astro.url.pathname, Astro.site)
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <!-- Fonts -->
  <Font cssVariable="--font-public-sans" preload />
  <Font cssVariable="--font-roboto-mono" preload />

  <!-- SEO, OpenGraph and Twitter -->
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="canonical" href={url} />
  {locales.map((l) => <link rel="alternate" hreflang={l} href={new URL(`/${l}/`, Astro.site)} />)}
  {Boolean(description) && <meta name="description" content={description} />}
  <meta property="og:site_name" content={t(lang, "site.title")} />
  <meta property="og:url" content={url} />
  <meta property="og:title" content={title} />
  {Boolean(description) && <meta property="og:description" content={description} />}
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  {Boolean(description) && <meta name="twitter:description" content={description} />}
  <meta name="twitter:creator" content="@zlliang96" />

  <!-- Title -->
  <title>{title}</title>
</head>
<body>
  <div class="flex flex-col min-h-dvh max-w-3xl m-auto px-6">
    <Header logo={logo} title={t(lang, "site.title")} homeHref={`/${lang}/`}>
      {showMenu && (
        <Fragment slot="menu">
          {locales.map((l) => lang === l ? null : <Link href={`/${l}/`}><span class="icon-[lucide--languages]" /> {t(l, "desc")}</Link>)}
        </Fragment>
      )}
    </Header>
    <main class="flex-1">
      <slot />
    </main>
    <Footer author={t(lang, "site.title")} builtWithPrefix={t(lang, "ui.footer.builtWithPrefix")} builtWithSuffix={t(lang, "ui.footer.builtWithSuffix")} />
  </div>

  <!-- Vercel -->
  <VercelWebAnalytics />
  <VercelSpeedInsights />
</body>
</html>
