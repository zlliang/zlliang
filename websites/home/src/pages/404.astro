---
import Layout from "@zlliang/theme/components/Layout.astro"

import logo from "@/assets/logo.png"
import { t } from "@/utils/i18n"
---

<Layout
  title="404 Not Found / 找不到页面"
  locale="en"
  logo={logo}
  siteTitle={t("en", "site.title")}
  aside={false}
>
  <div class="flex flex-col justify-center items-center mt-32 text-neutral-400 dark:text-neutral-600">
    <div class="icon-[lucide--frown] text-5xl" />
    <div class="mt-2 text-2xl font-display font-bold">404 Not Found / 找不到页面</div>
    <a href="/" class="mt-6"><span class="icon-[lucide--arrow-left]" /> Back to home / 返回首页</a>
  </div>
</Layout>
