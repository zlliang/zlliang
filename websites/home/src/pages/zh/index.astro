---
import { Image } from "astro:assets"

import Section from "@zlliang/theme/components/Section.astro"
import Layout from "@/components/Layout.astro"

import { renderFragment } from "@/utils/content"

import logoTech from "@/assets/images/logo-tech.png"
import logoDays from "@/assets/images/logo-days.png"

const Bio = await renderFragment("bio-zh")
---

<Layout lang="zh">
  <div class="mb-12">
    <Bio />
  </div>

  {/* Writing */}
  <Section title="写作">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <a href="https://tech.zlliang.me" class="secondary group flex gap-4 p-4 border border-neutral-200 dark:border-neutral-800 hover:border-tech-400 dark:hover:border-tech-600 hover:bg-tech-50 dark:hover:bg-tech-950 hover:text-tech-500!">
        <Image src={logoTech} alt="tech.zlliang.me 的图标" class="size-8" loading="eager" />
        <div class="flex-1">
          <div><span class="font-bold">子龙的技术笔记</span> (英文)</div>
          <div class="text-sm text-neutral-500 group-hover:text-tech-400 dark:group-hover:text-tech-600">tech.zlliang.me</div>
          <div class="mt-2 text-sm">我的技术探索日志</div>
        </div>
      </a>
      <a href="https://days.zlliang.me" class="secondary group flex gap-4 p-4 border border-neutral-200 dark:border-neutral-800 hover:border-days-400 dark:hover:border-days-600 hover:bg-days-50 dark:hover:bg-days-950 hover:text-days-500!">
        <Image src={logoDays} alt="days.zlliang.me 的图标" class="size-8" loading="eager" />
        <div class="flex-1">
          <div><span class="font-bold">子龙的生活手记</span> (中文)</div>
          <div class="text-sm text-neutral-500 group-hover:text-days-400 dark:group-hover:text-days-600">days.zlliang.me</div>
          <div class="mt-2 text-sm">我的生活感悟日志</div>
        </div>
      </a>
    </div>
  </Section>
</Layout>
