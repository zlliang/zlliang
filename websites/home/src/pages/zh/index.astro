---
import Layout from "@zlliang/theme/components/Layout.astro"
import Section from "@zlliang/theme/components/Section.astro"
import SiteCard from "@zlliang/theme/components/SiteCard.astro"

import { getLayoutProps } from "@/utils/site"
import { locales, t } from "@/utils/i18n"
import { renderFragment } from "@/utils/content"

const Bio = await renderFragment("bio-zh")
---

<Layout {...getLayoutProps("zh")}>
  <Fragment slot="menu">
    {locales.filter((l) => l !== "zh").map((l) => <a href={`/${l}/`}><span class="icon-[lucide--languages]" /> {t(l, "desc")}</a>)}
  </Fragment>

  <div class="mb-12">
    <Bio />
  </div>

  {/* Journals */}
  <Section title="手记">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <SiteCard site="mesh" lang="zh" />
      <SiteCard site="muse" lang="zh" />
    </div>
  </Section>
</Layout>
