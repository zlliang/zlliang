---
import PageTitle from "@zlliang/theme/components/PageTitle.astro"
import Layout from "@/components/Layout.astro"
import SearchForm from "@/components/SearchForm.astro"
import NoteSearchResults from "@/components/NoteSearchResults.astro"

import { paginate, parsePageParam, shouldRedirectPagination } from "@/utils/pagination"
import { getSearchPageUrl, parseSearchSort, searchNotes } from "@/utils/search"

import type { SearchSort } from "@/utils/search"

Astro.response.headers.set("Cache-Control", "public, max-age=0, s-maxage=60")

const searchParams = Astro.url.searchParams
const q = searchParams.get("q")?.trim() ?? ""
const page = parsePageParam(searchParams.get("page"))
const sort = parseSearchSort(searchParams.get("sort"))

if (!q && (searchParams.has("q") || searchParams.has("page"))) {
  return Astro.redirect("/notes/search")
}

if (searchParams.has("sort") && searchParams.get("sort") !== "date") {
  return Astro.redirect(getSearchPageUrl(q, page, sort))
}

const results = q ? await searchNotes(q) : []
const sortedResults = sort === "date" ? results.toSorted((a, b) => b.data.number - a.data.number) : results

const pagination = paginate(sortedResults, page, (page) => getSearchPageUrl(q, page, sort))
if (q && shouldRedirectPagination(searchParams, page, pagination)) {
  return Astro.redirect(pagination.url.current)
}

const sortUrls = {
  relevance: getSearchPageUrl(q, 1, "relevance"),
  date: getSearchPageUrl(q, 1, "date"),
}

function getSearchSortDisplay(sort: SearchSort) {
  return sort === "relevance" ? "relevance" : "date"
}

const title = q ? `Search results for "${q}"` : "Search"
---

<Layout title={title} showSearch={false} noindex>
  {/* Title */}
  <PageTitle>
    <Fragment>{title}</Fragment>
    <span slot="subtitle">{q ? `${results.length} total` : "Please enter a search query"}</span>
  </PageTitle>

  {/* Search form */}
  <SearchForm q={q} class="mb-6" />

  {/* Search results */}
  {q && (
    results.length > 0 ? (
      <div class="pb-6 mb-6 border-b-2 border-neutral-200 dark:border-neutral-800">
        <div class="flex items-center text-sm gap-2">
          <span class="text-neutral-500">Sorted by</span>
          {(["relevance", "date"] as const).map((item) => (
            item === sort ? <span>{getSearchSortDisplay(item)}</span> : <a href={sortUrls[item]}>{getSearchSortDisplay(item)}</a>
          ))}
        </div>
      </div>
      <NoteSearchResults notes={pagination.data} pagination={pagination} />
    ) : <p class="text-neutral-500">No notes found for "{q}".</p>
  )}
</Layout>
