---
import { format } from "date-fns"
import { countBy } from "lodash-es"

import PageTitle from "@zlliang/theme/components/PageTitle.astro"
import Section from "@zlliang/theme/components/Section.astro"
import Layout from "@/components/Layout.astro"
import ArchiveLinks from "@/components/ArchiveLinks.astro"
import NoteList from "@/components/NoteList.astro"

import { getNotes } from "@/utils/content"
import { paginate, parsePageParam, shouldRedirectPagination } from "@/utils/pagination"
import { getArchiveBounds, getMonthNotesPath, getYearNotesPath, parseYear } from "@/utils/archive"

const notes = await getNotes()

const { year: yearSegment } = Astro.params
const year = parseYear(yearSegment)
const bounds = getArchiveBounds(notes)
if (year === null || bounds === null) {
  return Astro.rewrite("/404")
}

const yearRange = bounds.getYearRange()
if (year < yearRange.start || year > yearRange.end) {
  return Astro.rewrite("/404")
}

const filteredNotes = notes.filter((note) => note.data.created.getFullYear() === year)

const yearCounts = countBy(notes, (note) => note.data.created.getFullYear())
const yearItems = Array.from({ length: yearRange.end - yearRange.start + 1 }, (_, index) => {
  const y = yearRange.start + index
  const count = yearCounts[y] ?? 0

  return {
    label: String(y),
    count,
    href: count > 0 ? getYearNotesPath(y) : undefined,
    active: y === year,
  }
})

const monthRange = bounds.getMonthRange(year)!
const monthCounts = countBy(filteredNotes, (note) => note.data.created.getMonth() + 1)
const monthItems = Array.from({ length: monthRange.end - monthRange.start + 1 }, (_, index) => {
  const m = monthRange.start + index
  const count = monthCounts[m] ?? 0

  return {
    label: format(new Date(year, m - 1, 1), "MMM"),
    count,
    href: count > 0 ? getMonthNotesPath(year, m) : undefined,
  }
})

const searchParams = Astro.url.searchParams
const page = parsePageParam(searchParams.get("page"))

function getPageUrl(page: number) {
  const params = new URLSearchParams()

  if (page > 1) {
    params.set("page", page.toString())
  }

  const basePath = getYearNotesPath(year!)
  return params.size > 0 ? `${basePath}?${params}` : basePath
}

const pagination = paginate(filteredNotes, page, getPageUrl)

if (shouldRedirectPagination(searchParams, page, pagination)) {
  return Astro.redirect(pagination.url.current)
}

const title = `Notes in ${year}`
---

<Layout title={title}>
  {/* Archive */}
  <Fragment slot="aside-prefix">
    <Section title="Archive">
      <div class="mb-2 text-xs text-neutral-500">Years</div>
      <ArchiveLinks items={yearItems} />
      <div class="mt-4 mb-2 text-xs text-neutral-500">{year}</div>
      <ArchiveLinks items={monthItems} />
    </Section>
  </Fragment>

  {/* Title */}
  <PageTitle>
    <Fragment>{title}</Fragment>
    <div slot="subtitle" class="flex justify-between gap-4">
      <span>{pagination.total} total</span>
      <a href="/notes"><span class="icon-[lucide--corner-left-up]" /> Back to all notes</a>
    </div>
  </PageTitle>

  {/* Notes */}
  {pagination.data.length > 0 ? <NoteList notes={pagination.data} pagination={pagination} /> : <p class="text-neutral-500">No notes found.</p>}
</Layout>
