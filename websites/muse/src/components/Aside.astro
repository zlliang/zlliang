---
import Section from "@zlliang/theme/components/Section.astro"
import SiteCard from "@zlliang/theme/components/SiteCard.astro"
import PostList from "@/components/PostList.astro"
import SearchForm from "@/components/SearchForm.astro"
import Heatmap from "@/components/Heatmap.astro"

import { getNotes, getPosts, getPinnedPosts, getSeries } from "@/utils/content"

import { cn } from "@zlliang/theme"

interface Props {
  showSearch?: boolean
  showRecentPosts?: boolean
  class?: string
}

const { showSearch = true, showRecentPosts = true, class: className } = Astro.props
const notes = await getNotes()
const posts = await getPosts()
const pinnedPosts = await getPinnedPosts()
const recentPosts = posts.slice(0, 10)
const series = await getSeries()
---

<aside class={cn("space-y-6", className)}>
  {showSearch && <SearchForm class="hidden lg:flex mb-6" />}

  {/* Prefix */}
  <slot name="prefix" />

  {/* Explore */}
  <Section title="探索">
    <div class="flex justify-between items-center mb-1">
      <a href="/notes"><span class="icon-[lucide--notebook-pen]" /> 手记</a>
      <span class="text-sm text-neutral-500">
        <span>{notes.length} 则</span>
      </span>
    </div>
    <div class="flex justify-between items-center">
      <a href="/posts"><span class="icon-[lucide--book-open-text]" /> 文章</a>
      <span class="text-sm text-neutral-500">
        <span>{posts.length} 篇</span><span class="icon-[lucide--dot]" /><a href="/posts/series">{series.length} 个系列</a>
      </span>
    </div>
    <Heatmap />
  </Section>

  {/* Pinned posts */}
  {pinnedPosts.length > 0 && (
    <Section title="置顶文章">
      <PostList posts={pinnedPosts} showMeta={false} />
    </Section>
  )}

  {/* Recent posts */}
  {showRecentPosts && recentPosts.length > 0 && (
    <Section title="近期文章">
      <PostList posts={recentPosts} />
    </Section>
  )}

  {/* Other websites */}
  <Section title="我的另一面">
    <SiteCard site="hack" lang="zh" />
  </Section>

  {/* Suffix */}
  <slot name="suffix" />
</aside>
