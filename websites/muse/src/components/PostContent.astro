---
import { render } from "astro:content"
import { format } from "date-fns"

import PageTitle from "@zlliang/theme/components/PageTitle.astro"

import { getSeriesById } from "@/utils/content"

import type { CollectionEntry } from "astro:content"

interface Props {
  post: CollectionEntry<"posts">
}

const { post } = Astro.props
const series = post.data.series ? await getSeriesById(post.data.series.id) : null
const { Content } = await render(post)
---

<div class="post-content">
  {/* Title */}
  <PageTitle>
    <Fragment>{post.data.title}</Fragment>
    <div slot="subtitle">
      <span>{format(post.data.created, "yyyy 年 M 月 d 日")}</span>
      {post.data.pinned && <span class="icon-[lucide--pin]" />}
      {series && <span class="ml-1">连载于系列：<a href={`/posts/series/${series.id}`}>{series.data.title}</a></span>}
      {post.data.draft && <span class="ml-1 text-amber-600 dark:text-amber-400">草稿</span>}
    </div>
  </PageTitle>

  {/* Content */}
  <div class="mb-4">
    <Content />
  </div>
</div>
