---
import PageTitle from "@zlliang/theme/components/PageTitle.astro"
import Layout from "@/components/Layout.astro"
import PostList from "@/components/PostList.astro"

import { getPosts } from "@/utils/content"

const posts = await getPosts()
const title = "文章"
---

<Layout title={title} showRecentPosts={false}>
  {/* Title */}
  <PageTitle>
    <Fragment>{title}</Fragment>
    <span slot="subtitle">共 {posts.length} 篇</span>
  </PageTitle>

  {/* Posts */}
  {posts.length > 0 ? <PostList posts={posts} /> : <p class="text-neutral-500">暂无文章。</p>}
</Layout>
