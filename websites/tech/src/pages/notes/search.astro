---
import PageTitle from "@zlliang/theme/components/PageTitle.astro"
import Layout from "@/components/Layout.astro"
import SearchForm from "@/components/SearchForm.astro"
import NoteList from "@/components/NoteList.astro"

import { paginate, parsePageParam, shouldRedirectPagination } from "@/utils/pagination"
import { getSearchPageUrl, searchNotes } from "@/utils/search"

const searchParams = Astro.url.searchParams
const q = searchParams.get("q")?.trim() ?? ""
const page = parsePageParam(searchParams.get("page"))

if (!q && (searchParams.has("q") || searchParams.has("page"))) {
  return Astro.redirect("/notes/search")
}

const results = q ? await searchNotes(q) : []
const pagination = paginate(results, page, (page) => getSearchPageUrl(q, page))

if (q && shouldRedirectPagination(searchParams, page, pagination)) {
  return Astro.redirect(pagination.url.current)
}

const title = q ? `Search results for "${q}"` : "Search"
---

<Layout title={title} showSearch={false} noindex>
  <!-- Title -->
  <PageTitle>
    <Fragment>{title}</Fragment>
    <span slot="subtitle">{q ? `${results.length} total` : "Please enter a search query"}</span>
  </PageTitle>

  <!-- Search form -->
  <SearchForm q={q} class="mb-6" />

  <!-- Search results -->
  {q && (results.length > 0 ? <NoteList notes={pagination.data} pagination={pagination} /> : <p class="text-neutral-500">No notes found for "{q}".</p>)}
</Layout>
