{
  "name": "zlliang",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm -r --parallel --filter @zlliang/home --filter @zlliang/mesh --filter @zlliang/muse dev",
    "dev:home": "pnpm --filter @zlliang/home dev",
    "dev:mesh": "pnpm --filter @zlliang/mesh dev",
    "dev:muse": "pnpm --filter @zlliang/muse dev",
    "build": "pnpm -r --reporter=append-only --filter @zlliang/home --filter @zlliang/mesh --filter @zlliang/muse build",
    "build:home": "pnpm --filter @zlliang/home build",
    "build:mesh": "pnpm --filter @zlliang/mesh build",
    "build:muse": "pnpm --filter @zlliang/muse build",
    "toolkit:mesh": "pnpm exec toolkit --dir websites/mesh",
    "toolkit:muse": "pnpm exec toolkit --dir websites/muse"
  },
  "lint-staged": {
    "*.{jpg,jpeg,png,webp,avif}": "pnpm exec toolkit optimize-image",
    "*.{astro,md,mdx}": "pnpm exec toolkit replace-text"
  },
  "devDependencies": {
    "@zlliang/toolkit": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8"
}
