{
  "name": "zlliang",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm -r --parallel --filter @zlliang/home --filter @zlliang/tech --filter @zlliang/days dev",
    "build": "pnpm -r --filter @zlliang/home --filter @zlliang/tech --filter @zlliang/days build",
    "dev:home": "pnpm --filter @zlliang/home dev",
    "build:home": "pnpm --filter @zlliang/home build",
    "dev:tech": "pnpm --filter @zlliang/tech dev",
    "build:tech": "pnpm --filter @zlliang/tech build",
    "journal:tech": "pnpm --dir websites/tech journal",
    "dev:days": "pnpm --filter @zlliang/days dev",
    "build:days": "pnpm --filter @zlliang/days build",
    "journal:days": "pnpm --dir websites/days journal"
  },
  "lint-staged": {
    "*.{jpg,jpeg,png,webp,avif}": "pnpm exec journal optimize-image"
  },
  "devDependencies": {
    "@zlliang/journal": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^6.0.2"
  }
}
