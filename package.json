{
  "name": "zlliang",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm -r --parallel --filter @zlliang/home --filter @zlliang/mesh --filter @zlliang/muse dev",
    "dev:home": "pnpm --filter @zlliang/home dev",
    "dev:mesh": "pnpm --filter @zlliang/mesh dev",
    "dev:muse": "pnpm --filter @zlliang/muse dev",
    "build": "pnpm -r --reporter=append-only --filter @zlliang/home --filter @zlliang/mesh --filter @zlliang/muse build",
    "build:home": "pnpm --filter @zlliang/home build",
    "build:mesh": "pnpm --filter @zlliang/mesh build",
    "build:muse": "pnpm --filter @zlliang/muse build",
    "scripts:mesh": "pnpm exec scripts --dir websites/mesh",
    "scripts:muse": "pnpm exec scripts --dir websites/muse"
  },
  "lint-staged": {
    "*.{jpg,jpeg,png,webp,avif}": "pnpm exec scripts optimize-image"
  },
  "devDependencies": {
    "@zlliang/scripts": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
