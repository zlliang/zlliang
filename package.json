{
  "name": "zlliang",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm -r --if-present dev",
    "dev:home": "pnpm --filter @zlliang/home dev",
    "dev:mesh": "pnpm --filter @zlliang/mesh dev",
    "dev:muse": "pnpm --filter @zlliang/muse dev",
    "build": "pnpm -r --if-present build",
    "build:home": "pnpm --filter @zlliang/home build",
    "build:mesh": "pnpm --filter @zlliang/mesh build",
    "build:muse": "pnpm --filter @zlliang/muse build",
    "toolkit:mesh": "pnpm exec toolkit --dir websites/mesh",
    "toolkit:muse": "pnpm exec toolkit --dir websites/muse"
  },
  "lint-staged": {
    "*.{jpg,jpeg,png,webp,avif}": "pnpm exec toolkit optimize-image",
    "*.{astro,md,mdx}": "pnpm exec toolkit replace-text"
  },
  "devDependencies": {
    "@zlliang/toolkit": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.17.0+sha512.cca3cea332ad254bb84145f966d19f4879615210346fc92c79a047f23a0d7b3cca3c3792f0076ba1f1831d277efbcf0a9119b31a9a60eca7fb3d6231f331ef72"
}
