{
  "name": "zlliang",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm -r --parallel --filter @zlliang/home --filter @zlliang/hack --filter @zlliang/muse dev",
    "build": "pnpm -r --filter @zlliang/home --filter @zlliang/hack --filter @zlliang/muse build",
    "dev:home": "pnpm --filter @zlliang/home dev",
    "build:home": "pnpm --filter @zlliang/home build",
    "dev:hack": "pnpm --filter @zlliang/hack dev",
    "build:hack": "pnpm --filter @zlliang/hack build",
    "journal:hack": "pnpm exec journal --dir websites/hack",
    "dev:muse": "pnpm --filter @zlliang/muse dev",
    "build:muse": "pnpm --filter @zlliang/muse build",
    "journal:muse": "pnpm exec journal --dir websites/muse"
  },
  "lint-staged": {
    "*.{jpg,jpeg,png,webp,avif}": "pnpm exec journal optimize-image"
  },
  "devDependencies": {
    "@zlliang/journal": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^6.0.2"
  }
}
