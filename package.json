{
  "name": "zlliang",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm -r --parallel --filter @zlliang/www --filter @zlliang/tech --filter @zlliang/days dev",
    "build": "pnpm -r --filter @zlliang/www --filter @zlliang/tech --filter @zlliang/days build",
    "optimize-image": "tsx scripts/optimize-image.ts",
    "dev:www": "pnpm --filter @zlliang/www dev",
    "build:www": "pnpm --filter @zlliang/www build",
    "dev:tech": "pnpm --filter @zlliang/tech dev",
    "build:tech": "pnpm --filter @zlliang/tech build",
    "journal:tech": "pnpm --dir websites/tech journal",
    "dev:days": "pnpm --filter @zlliang/days dev",
    "build:days": "pnpm --filter @zlliang/days build",
    "journal:days": "pnpm --dir websites/days journal"
  },
  "devDependencies": {
    "@zlliang/journal": "workspace:*",
    "husky": "^9.1.7",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
