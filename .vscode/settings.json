{
  // Tailwind CSS
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "tailwindCSS.includeLanguages": {
    "astro": "html"
  },
  "tailwindCSS.experimental.classRegex": [
    ["class:list\\s*=\\s*{([^}]*)}"],
    ["class(?::list)?\\s*=\\s*['\"]([^'\"]*)['\"]"]
  ],

  // Markdown
  "[markdown]": {
    "editor.quickSuggestions": {
      "other": "on"
    }
  }
}
